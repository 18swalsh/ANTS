{
  "appId": "com.ants.bandcampuploader",
  "productName": "ANTS Bandcamp Uploader",
  "directories": {
    "output": "dist"
  },
  "asar": false,
  "files": [
    "**/*",
    "!**/dist/**",
    "!**/*.zip",
    "!**/mac-build-package.zip",
    "!**/_mac_build_stage/**",
    "!**/node_modules/playwright/.local-browsers/**",
    "!**/node_modules/playwright-core/.local-browsers/**",
    "!**/playwright-browsers/**"
  ],
  "mac": {
    "target": ["zip"],
    "icon": "build/icons/ants.icns",
    "category": "public.app-category.music"
  },
  "win": {
    "target": ["zip"],
    "icon": "build/icons/ants.ico"
  },
  "extraResources": []
}
