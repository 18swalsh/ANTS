{
  "appId": "com.ants.bandcampuploader",
  "productName": "ANTS Bandcamp Uploader",
  "directories": {
    "output": "dist"
  },
  "asar": false,
  "files": [
    "**/*",
    "!**/dist/**",
    "!**/*.zip",
    "!**/mac-build-package.zip",
    "!**/_mac_build_stage/**"
  ],
  "mac": {
    "target": ["zip"],
    "category": "public.app-category.music"
  },
  "win": {
    "target": ["zip"]
  },
  "extraResources": [
    {
      "from": "node_modules/playwright/.local-browsers",
      "to": "playwright-browsers",
      "filter": ["**/*"]
    }
  ]
}
