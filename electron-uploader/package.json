{
  "name": "ants-bandcamp-uploader",
  "version": "0.1.0",
  "private": true,
  "description": "ANTS Bandcamp Uploader (Electron)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "cross-env PLAYWRIGHT_BROWSERS_PATH=0 playwright install chromium",
    "pack:mac": "electron-builder --mac --config electron-builder.json",
    "pack:win": "electron-builder --win --config electron-builder.json"
  },
  "dependencies": {
    "extract-zip": "^2.0.1",
    "playwright": "^1.47.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "cross-env": "^7.0.3"
  }
}
